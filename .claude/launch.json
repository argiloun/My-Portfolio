{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "portfolio",
      "runtimeExecutable": "C:/Program Files/nodejs/node.exe",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path'),m={'html':'text/html','css':'text/css','js':'application/javascript','png':'image/png','jpg':'image/jpeg','svg':'image/svg+xml','ico':'image/x-icon','json':'application/json'};h.createServer((q,r)=>{let u=q.url.split('?')[0];if(u==='/')u='/index.html';const fp=p.join(process.cwd(),u),e=p.extname(fp).slice(1);f.readFile(fp,(err,d)=>{if(err){r.writeHead(404);r.end('Not found');}else{r.writeHead(200,{'Content-Type':m[e]||'application/octet-stream'});r.end(d);}});}).listen(3000,()=>console.log('Server on 3000'));"],
      "port": 3000
    }
  ]
}
